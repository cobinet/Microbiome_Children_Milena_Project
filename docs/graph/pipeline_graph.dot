digraph MILENA_Pipeline {
    graph [rankdir=LR, fontname="Helvetica", splines=ortho];
    node  [fontname="Helvetica", fontsize=10];
    edge  [fontname="Helvetica", fontsize=8];

    "ASV_table" [label="ASV_table.tsv\n(relative abundance)", shape=box, style=filled, fillcolor="#AED6F1"];
    "ASV_tax" [label="ASV_tax_species.user.tsv\n(taxonomy)", shape=box, style=filled, fillcolor="#AED6F1"];
    "EC_raw" [label="EC_pred_metagenome_unstrat.tsv\n(PICRUSt2 EC)", shape=box, style=filled, fillcolor="#AED6F1"];
    "KO_raw" [label="KO_pred_metagenome_unstrat.tsv\n(PICRUSt2 KO)", shape=box, style=filled, fillcolor="#AED6F1"];
    "MetaCyc_raw" [label="METACYC_path_abun_unstrat.tsv\n(PICRUSt2 MC)", shape=box, style=filled, fillcolor="#AED6F1"];
    "metadata_xlsx" [label="data_formicrobiome.xlsx\n(clinical metadata)", shape=box, style=filled, fillcolor="#AED6F1"];
    "nb_preproc" [label="funAnalysis_metagPastoKids.ipynb\n[Python/Jupyter]", shape=diamond, style=filled, fillcolor="#A9DFBF"];
    "r_assoc" [label="AssocAnalysis.R\n[R]", shape=diamond, style=filled, fillcolor="#A9DFBF"];
    "r_graph" [label="build_pipeline_graph.py\n[Python]", shape=diamond, style=filled, fillcolor="#A9DFBF"];
    "asv_clr" [label="asv_table_clr_transformed.tsv", shape=ellipse, style=filled, fillcolor="#FAD7A0"];
    "KO_clr" [label="KO_Functions_clr_transformed.tsv", shape=ellipse, style=filled, fillcolor="#FAD7A0"];
    "EC_clr" [label="EC_Functions_clr_transformed.tsv", shape=ellipse, style=filled, fillcolor="#FAD7A0"];
    "MC_clr" [label="MetaCyc_Pathways_clr_transformed.tsv", shape=ellipse, style=filled, fillcolor="#FAD7A0"];
    "meta_clean" [label="metadata_clean.csv", shape=ellipse, style=filled, fillcolor="#FAD7A0"];
    "tax_clean" [label="asv_taxonomy_clean.csv", shape=ellipse, style=filled, fillcolor="#FAD7A0"];
    "html_table" [label="{TARGET}_publication_table.html", shape=parallelogram, style=filled, fillcolor="#D2B4DE"];
    "lollipop_png" [label="{TARGET}_lollipop_*.png", shape=parallelogram, style=filled, fillcolor="#D2B4DE"];
    "volcano_png" [label="volcano_{BLOCK}_{contrast}.png", shape=parallelogram, style=filled, fillcolor="#D2B4DE"];
    "csv_results" [label="{TARGET}_ALL_features_all_contrasts.csv", shape=parallelogram, style=filled, fillcolor="#D2B4DE"];
    "graph_dot" [label="pipeline_graph.dot", shape=parallelogram, style=filled, fillcolor="#D2B4DE"];
    "graph_png" [label="pipeline_graph.png", shape=parallelogram, style=filled, fillcolor="#D2B4DE"];

    "ASV_table" -> "nb_preproc" [label="reads"];
    "ASV_tax" -> "nb_preproc" [label="reads"];
    "EC_raw" -> "nb_preproc" [label="reads"];
    "KO_raw" -> "nb_preproc" [label="reads"];
    "MetaCyc_raw" -> "nb_preproc" [label="reads"];
    "metadata_xlsx" -> "nb_preproc" [label="reads"];
    "nb_preproc" -> "asv_clr" [label="CLR transform"];
    "nb_preproc" -> "KO_clr" [label="CLR transform"];
    "nb_preproc" -> "EC_clr" [label="CLR transform"];
    "nb_preproc" -> "MC_clr" [label="CLR transform"];
    "nb_preproc" -> "meta_clean" [label="QC + clean"];
    "nb_preproc" -> "tax_clean" [label="QC + clean"];
    "r_assoc" -> "html_table" [label="gt export"];
    "r_assoc" -> "lollipop_png" [label="ggplot2"];
    "r_assoc" -> "volcano_png" [label="ggplot2"];
    "r_assoc" -> "csv_results" [label="write_csv"];
    "r_graph" -> "graph_dot" [label="networkx export"];
    "r_graph" -> "graph_png" [label="matplotlib render"];
    "asv_clr" -> "r_assoc" [label="reads"];
    "KO_clr" -> "r_assoc" [label="reads"];
    "EC_clr" -> "r_assoc" [label="reads"];
    "MC_clr" -> "r_assoc" [label="reads"];
    "meta_clean" -> "r_assoc" [label="reads"];
    "tax_clean" -> "r_assoc" [label="reads"];
}